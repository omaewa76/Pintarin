      "name": "1. Authentication",
      "item": [
        {
          "name": "Login - Dinas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Response has access_token', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.have.property('access_token');",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                  "  pm.collectionVariables.set('refreshToken', jsonData.data.refresh_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@dinas.bandung.go.id\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
